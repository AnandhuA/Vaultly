{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Pub Get (FVM)",
      "type": "shell",
      "command": "${workspaceFolder}\\.fvm\\flutter_sdk\\bin\\flutter.bat",
      "args": ["pub", "get"],
      "problemMatcher": []
    },
    {
      "label": "Flutter: Analyze (FVM)",
      "type": "shell",
      "command": "${workspaceFolder}\\.fvm\\flutter_sdk\\bin\\dart.bat",
      "args": ["analyze", "lib", "test"],
      "problemMatcher": "$dart-analyzer"
    },
    {
      "label": "Flutter: Test (FVM)",
      "type": "shell",
      "command": "${workspaceFolder}\\.fvm\\flutter_sdk\\bin\\flutter.bat",
      "args": ["test"],
      "problemMatcher": "$dart-test"
    },
    {
      "label": "Flutter: Build Debug APK (FVM)",
      "type": "shell",
      "command": "${workspaceFolder}\\.fvm\\flutter_sdk\\bin\\flutter.bat",
      "args": ["build", "apk", "--debug"],
      "problemMatcher": []
    }
  ]
}
